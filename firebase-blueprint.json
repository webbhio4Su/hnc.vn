{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "className": { "type": "string" },
        "avatar": { "type": "string" },
        "background": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "role": { "type": "string", "enum": ["student", "teacher", "parent", "admin", "user"] },
        "isAdmin": { "type": "boolean" },
        "points": { "type": "number" },
        "hncoi": { "type": "number" },
        "childEmails": { "type": "array", "items": { "type": "string" } },
        "managedClasses": { "type": "array", "items": { "type": "string" } },
        "uid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "uid"]
    },
    "Post": {
      "title": "Post",
      "description": "Social feed post",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" },
        "likes": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "content", "timestamp"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comment on a post",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["authorId", "content", "timestamp"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A conversation between two users",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "number" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a conversation",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["senderId", "content", "timestamp"]
    },
    "VersusMatch": {
      "title": "VersusMatch",
      "description": "A 1v1 match between two players",
      "type": "object",
      "properties": {
        "players": { "type": "object" },
        "status": { "type": "string", "enum": ["waiting", "playing", "finished"] },
        "winner": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["players", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Users collection"
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Global feed posts"
    },
    "posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a post"
    },
    "conversations/{convId}": {
      "schema": "Conversation",
      "description": "Active conversations"
    },
    "conversations/{convId}/messages/{msgId}": {
      "schema": "Message",
      "description": "Messages within a conversation"
    },
    "matches/{matchId}": {
      "schema": "VersusMatch",
      "description": "1v1 matches"
    }
  }
}
